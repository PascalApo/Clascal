# Supabase – Echtzeit-Sync für Clara & Pascal
# SQL ausführen: supabase/schema.sql (ggf. migration_radar.sql)
# Project Settings → API → Project URL (Format: https://<ref>.supabase.co)
# NICHT api.supabase.com/platform oder Dashboard-Links verwenden!
#
# Lokal: diese Datei als .env.local kopieren
# GitHub Pages: dieselben Variablen als Repository Secrets (Settings → Secrets → Actions)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_HOUSEHOLD_ID=clara-pascal

# Web Push (Partner-Benachrichtigungen, iOS PWA ab 16.4)
# Schlüssel erzeugen: npx web-push generate-vapid-keys
# Öffentlichen Schlüssel hier + als GitHub Actions Variable VITE_VAPID_PUBLIC_KEY
# Privaten Schlüssel nur in Supabase Edge Function Secrets: VAPID_PRIVATE_KEY, VAPID_PUBLIC_KEY, VAPID_EMAIL
VITE_VAPID_PUBLIC_KEY=

# Firebase (Alternative)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_DATABASE_URL=
